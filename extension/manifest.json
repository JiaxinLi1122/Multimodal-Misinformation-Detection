{
  "manifest_version": 3,
  "name": "Multi-False Detector",
  "version": "0.1.0",
  "description": "Prototype UI for multimodal misinformation detection.",

  "permissions": ["activeTab", "scripting"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Multi-False Detector"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
